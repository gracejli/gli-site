# Photo booth (`/apple-photo-booth`): copy this file to `.env.local` and fill in values
# from Firebase Console → Project settings → Your apps → Web app → Firebase SDK snippet (config object).

# Put the whole config object on one line as JSON. Wrapping in single quotes avoids escaping issues.
NEXT_PUBLIC_FIREBASE_CONFIG='{"apiKey":"","authDomain":"","projectId":"","storageBucket":"","messagingSenderId":"","appId":""}'

# If your Firestore path uses a different app id than `photo-booth-signpost`, set it here.
# NEXT_PUBLIC_PHOTO_BOOTH_ARTIFACT_APP_ID=photo-booth-signpost

# Optional dev-only: Firebase custom token (do not commit real tokens).
# NEXT_PUBLIC_FIREBASE_INITIAL_AUTH_TOKEN=
